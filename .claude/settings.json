{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Trading Copilot - permissions + env. MCP servers are configured separately in .mcp.json at project root (Claude Code requires that location for project-scope MCPs).",

  "permissions": {
    "allow": [
      "Read",
      "Write(D:/trading-copilot/data/**)",
      "Write(D:/trading-copilot/docs/samples/**)",
      "Edit(D:/trading-copilot/data/**)",
      "Glob",
      "Grep",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add data/**)",
      "Bash(git commit*)",
      "WebFetch",
      "TodoWrite"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Write(D:/trading-copilot/.env)",
      "Edit(D:/trading-copilot/.env)"
    ]
  },

  "env": {
    "TRADING_COPILOT_HOME": "D:/trading-copilot",
    "TRADING_COPILOT_OUTPUT_LANG": "Chinese"
  }
}
