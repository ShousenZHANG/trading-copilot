# ============================================================================
# Trading Copilot - Environment Variables
# Copy to .env and fill in. .env is gitignored.
# ============================================================================
# All keys are OPTIONAL. The plugin uses only the MCP servers you've enabled
# in .claude/settings.json. Free tiers are sufficient for personal research.

# ----------------------------------------------------------------------------
# LLM provider (use Claude Code's built-in auth instead — these are only for
# headless GitHub Actions runs)
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ----------------------------------------------------------------------------
# Market data MCPs
# ----------------------------------------------------------------------------

# Polygon.io — primary market data (stocks/options/forex/crypto)
# Free tier: 5 requests/min. Sign up: https://polygon.io/dashboard/signup
POLYGON_API_KEY=

# Alpha Vantage — backup, hosted MCP at mcp.alphavantage.co
# Free tier: 25 requests/day. Sign up: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Finnhub — news + financials + fundamentals
# Free tier: 60 requests/min. Sign up: https://finnhub.io/register
FINNHUB_API_KEY=

# Yahoo Finance — no key required (free, scraped)

# ----------------------------------------------------------------------------
# Macro + commodity MCPs
# ----------------------------------------------------------------------------

# FRED — Fed economic data (rates/CPI/yields/DXY)
# Free, unlimited. Sign up: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# GoldAPI — spot gold prices
# Free tier: 100 requests/month. Sign up: https://www.goldapi.io/
GOLD_API_KEY=

# ----------------------------------------------------------------------------
# Research / sentiment MCPs
# ----------------------------------------------------------------------------

# Exa — neural web search (Reddit/X/news/filings)
# Free trial: $10 credits. Sign up: https://exa.ai/
EXA_API_KEY=

# ----------------------------------------------------------------------------
# Persistence (optional — claude-mem works locally without keys)
# ----------------------------------------------------------------------------

# Supabase — Postgres + auth (for multi-user / cloud sync)
# Free tier: 500MB. Sign up: https://supabase.com/
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_PROJECT_REF=

# ----------------------------------------------------------------------------
# Notifications (Phase 6 — continuous tracking)
# ----------------------------------------------------------------------------

# Telegram bot for alerts
# Setup: https://t.me/BotFather  (create bot, get token + chat_id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
